# Copy to `.env` and fill in real values:  cp .env.example .env
#
# Your dotfiles repo (the Dockerfile clones this at build time).
DOTFILES_REPO=https://github.com/jhez03/dotfiles.git
# Branch/tag to clone (bump to force a fresh clone on rebuild).
DOTFILES_REF=main
#
# Host directory holding the projects you want to edit inside the container.
# It gets mounted at /workspace.
PROJECTS_DIR=/home/jhez03/projects
#
# Terminal type passed into the container (affects colors/keys).
TERM=tmux-256color
#
# Match the container's `dev` user to your host user so bind-mounted
# /workspace files stay owned by you (avoids permission-denied errors).
# Find your values with `id -u` / `id -g`. Defaults to 1000 if unset,
# which covers most single-user Linux/WSL setups.
USER_UID=1000
USER_GID=1000
#
# GID of the host's `docker` group, so `dev` can use the docker socket
# mounted in docker-compose.yml. Find yours with `getent group docker`.
DOCKER_GID=999
